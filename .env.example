# =========================================
# Bayes CRM - Environment Variables Template
# Copy this file to .env and fill in values.
# =========================================

# --- Database (Prisma) ---
# PostgreSQL connection string used by Prisma migrations and runtime.
# Example: postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bayes_crm?schema=public"

# --- Legacy JWT Auth (kept for migration compatibility) ---
# Secret used to sign legacy `session` JWT cookies.
JWT_SECRET="replace_with_a_long_random_secret"

# --- Supabase Auth (required for new auth flow) ---
# Public Supabase project URL (from Supabase project settings).
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Public anonymous key (safe for browser usage).
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Service role key (server-only, NEVER expose to browser).
# Used for invite flow and secure server-side user verification.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Base URL for generating redirect links in emails.
# Local dev: http://localhost:3000
# Production: https://bayes-crm.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional explicit callback URL used in docs / templates.
# If not set, app defaults to NEXT_PUBLIC_APP_URL/auth/callback
SUPABASE_AUTH_CALLBACK_URL="http://localhost:3000/auth/callback"

# --- Cron security (optional but recommended) ---
# Secret token required by scheduled notifications endpoint.
CRON_SECRET="replace_with_generated_secret"

# --- Node environment ---
NODE_ENV="development"
